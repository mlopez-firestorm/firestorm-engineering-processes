%% PROPOSED: Autonomy Behavior Development Pipeline
flowchart TD
classDef gate fill:#e74c3c,stroke:#c0392b,color:#fff
classDef milestone fill:#2ecc71,stroke:#27ae60,color:#fff
classDef feedback fill:#f39c12,stroke:#e67e22,color:#fff
classDef process fill:#e3f2fd,stroke:#90caf9,color:#1a237e
classDef artifact fill:#fff3bf,stroke:#ffcc02,color:#333
classDef external fill:#e0e0e0,stroke:#9e9e9e,color:#333

start([Behavior need identified]) --> req[Define behavior requirements]
req --> reqpkg(Requirements package)
reqpkg --> design[Algorithm design]
design --> designreview{Design review complete?}
designreview -->|No| redesign[Revise behavior design]
redesign --> design
designreview -->|Yes| critical{Terminal guidance or swarming?}
critical -->|Yes| safety[Enhanced safety review]
critical -->|No| sitl[Run SITL validation]
safety --> sitl
sitl --> sitlgate{SITL meets criteria?}
sitlgate -->|No| tune[Tune logic and models]
tune --> design
sitlgate -->|Yes| hitl[Run HITL validation]
hitl --> hitlgate{HITL integration ready?}
hitlgate -->|No| integrate[Resolve SW/HW interface issues]
integrate --> hitl
hitlgate -->|Yes| flightplan(Flight test readiness package)
flightplan --> entry{Flight test entry approved?}
entry -->|No| integrate
entry -->|Yes| flight[Execute flight test]
flight --> flightgate{Flight results acceptable?}
flightgate -->|No| rework[Return to SITL rework]
rework --> sitl
flightgate -->|Yes| analysis[Analyze performance]
analysis --> certify[Behavior certification]
certify --> release[Release and deploy]
release --> released((Behavior released))

class start,released external
class req,design,redesign,sitl,hitl,integrate,flight,analysis,certify,release process
class designreview,critical,sitlgate,hitlgate,entry,flightgate gate
class tune,rework feedback
class reqpkg,flightplan artifact
class safety milestone
