%% PROPOSED: New Product Development Phase-Gate Lifecycle
flowchart TD
classDef gate fill:#e74c3c,stroke:#c0392b,color:#fff
classDef milestone fill:#2ecc71,stroke:#27ae60,color:#fff
classDef feedback fill:#f39c12,stroke:#e67e22,color:#fff
classDef process fill:#e3f2fd,stroke:#90caf9,color:#1a237e
classDef artifact fill:#fff3bf,stroke:#ffcc02,color:#333
classDef external fill:#e0e0e0,stroke:#9e9e9e,color:#333

start([Program need identified]) --> concept[Concept and feasibility]
concept --> conops(ConOps and concept package)
conops --> srr{SRR}
srr -->|Pass| func((Functional baseline))
srr -->|Fail or rework| reworkReq[Refine concept and requirements]
reworkReq --> concept

func --> prelim[Preliminary design]
prelim --> prelimPkg(Preliminary design package)
prelimPkg --> pdr{PDR}
pdr -->|Pass| alloc((Allocated baseline))
pdr -->|Fail or rework| reworkPrelim[Rework preliminary design]
reworkPrelim --> prelim

alloc --> detail[Detailed design]
detail --> detailPkg(Detailed design package)
detailPkg --> cdr{CDR}
cdr -->|Pass| product((Product baseline))
cdr -->|Fail or rework| reworkDetail[Rework detailed design]
reworkDetail --> detail

product --> build[Build and integration]
build --> buildPkg(Integrated article ready)
buildPkg --> trr{TRR}
trr -->|Pass| test[Test and evaluation]
trr -->|Fail or rework| reworkReady[Restore build and test readiness]
reworkReady --> build

test --> testPkg(Test evidence package)
testPkg --> prr{PRR}
prr -->|Pass| production((Production authorized))
prr -->|Fail or rework| reworkProd[Close findings and re-test]
reworkProd --> test

class start external
class concept,prelim,detail,build,test process
class srr,pdr,cdr,trr,prr gate
class func,alloc,product,production milestone
class conops,prelimPkg,detailPkg,buildPkg,testPkg artifact
class reworkReq,reworkPrelim,reworkDetail,reworkReady,reworkProd feedback
