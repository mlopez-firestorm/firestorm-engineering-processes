%% PROPOSED: HW Feature-Driven ECO Process
flowchart TD
classDef gate fill:#e74c3c,stroke:#c0392b,color:#fff
classDef milestone fill:#2ecc71,stroke:#27ae60,color:#fff
classDef feedback fill:#f39c12,stroke:#e67e22,color:#fff
classDef process fill:#e3f2fd,stroke:#90caf9,color:#1a237e
classDef artifact fill:#fff3bf,stroke:#ffcc02,color:#333
classDef external fill:#e0e0e0,stroke:#9e9e9e,color:#333

start([Feature need identified]) --> capture[Capture change need]
capture --> ecr(ECR submitted)
ecr --> classify{Classify change}
classify -->|Major| major[Major path]
classify -->|Minor| minor[Minor path]
classify -->|Emergency| emergency[Emergency path]
major --> hwreview
minor --> hwreview
emergency --> hwreview

subgraph impact[Cross-functional impact review]
subgraph impacthw[HW assessment]
hwreview[HW impact review]
end
subgraph impactsw[SW assessment]
swreview[SW impact review]
end
subgraph impactauto[Autonomy assessment]
autoreview[Autonomy impact review]
end
subgraph impactaero[Aero assessment]
aeroreview[Aero impact review]
end
end

hwreview --> swreview
swreview --> autoreview
autoreview --> aeroreview
aeroreview --> qualityreview[Quality review]
qualityreview --> consolidate[Project Engineer consolidates impacts]
consolidate --> complete{Review complete?}
complete -->|No| rework[Rework ECR package]
rework --> ecr
complete -->|Yes| pedecision{Project Engineer approve?}
pedecision -->|Reject| reject((ECO rejected))
pedecision -->|Approve| release((ECO approved))
pedecision -->|Need override| svp{SVP override needed?}
svp -->|No| rework
svp -->|Yes| override((Emergency override approved))
release --> implement[Implement hardware change]
override --> implement
implement --> verify[FAI and verification]
verify --> effectivity[Assign effectivity]
effectivity --> issue[Release updated configuration]
issue --> closeout((ECO closed))

class start,closeout external
class capture,hwreview,swreview,autoreview,aeroreview,qualityreview,consolidate,implement,verify,effectivity,issue process
class classify,complete,pedecision,svp gate
class rework feedback
class ecr artifact
class major,minor,emergency,reject,release,override milestone
