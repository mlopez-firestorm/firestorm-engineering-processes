%% PROPOSED: FRACAS Field Issue Resolution Process
flowchart TD
    A([Field operator detects failure]) --> B[Log FRACAS report with serial, symptoms, and conditions]
    B --> C[Classify severity and priority]
    C --> D{Safety critical?}
    D -->|Yes| E[Contain issue and ground affected units]
    D -->|No| G[Contain issue with interim action]
    E --> F[Issue safety notice]
    F --> H[Launch cross-functional investigation]
    G --> H
    H --> I[Perform root cause analysis]
    I --> J[Tag cause category]
    J --> K[Define corrective action]
    K --> L{Design change needed?}
    L -->|Yes| M[Create ECR]
    M --> N[Execute Workflow 01 ECO process]
    N --> O[Implement approved hardware change]
    L -->|No| P{Procedure or process change?}
    P -->|Yes| Q[Implement procedure or process update]
    P -->|No| R[Approve risk acceptance]
    O --> S[Verify corrective action]
    Q --> S
    R --> S
    S --> T{Recurrence found?}
    T -->|Yes| H
    T -->|No| U[Conduct effectiveness review]
    U --> V[Update FMEA and lessons learned]
    V --> W((Close FRACAS record))

    classDef gate fill:#e74c3c,stroke:#c0392b,color:#fff
    classDef milestone fill:#2ecc71,stroke:#27ae60,color:#fff
    classDef feedback fill:#f39c12,stroke:#e67e22,color:#fff
    classDef process fill:#e3f2fd,stroke:#90caf9,color:#1a237e
    classDef artifact fill:#fff3bf,stroke:#ffcc02,color:#333
    classDef external fill:#e0e0e0,stroke:#9e9e9e,color:#333

    class A external
    class B,V artifact
    class C,E,F,G,H,I,J,K,M,O,Q,S,U process
    class D,L,P,T gate
    class N external
    class R feedback
    class W milestone
